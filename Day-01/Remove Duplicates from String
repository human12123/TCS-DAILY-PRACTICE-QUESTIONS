#include <bits/stdc++.h>
using namespace std;

string removeDuplicates(string str) {
    unordered_set<char> seen;
    string result;

    for (char ch : str) {
        if (seen.find(ch) == seen.end()) {
            result += ch;
            seen.insert(ch);
        }
    }

    return result;
}

int main() {
    string str;
    getline(cin, str);

    cout << removeDuplicates(str);

    return 0;
}
