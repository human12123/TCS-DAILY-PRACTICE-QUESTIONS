#include<bits/stdc++.h>
using namespace std;

int findGCD(int a,int b){
    while(b!=0){    
    int temp=a%b;
    a=b;
    b=temp;
}
 return a;
}

long long findLCM(long long a,long long  b){
return (a/findGCD(a,b)*b);
}

int main(){
    int n;
    cin>>n;
    vector<int>arr(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    long long lcm=arr[0];
    for(int i=1;i<n;i++){
        lcm=findLCM(lcm,arr[i]);
    }
    cout<<lcm;
    return 0;
}
